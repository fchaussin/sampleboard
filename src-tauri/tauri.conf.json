{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sampleboard",
  "version": "0.12.0",
  "identifier": "org.sampleboard.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Sampleboard",
        "width": 420,
        "height": 760,
        "minWidth": 320,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; media-src 'self' asset: http://asset.localhost blob:; img-src 'self' asset: http://asset.localhost data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Music",
    "shortDescription": "Pads déclencheurs de sons (soundboard).",
    "longDescription": "Sampleboard : application de pads déclencheurs de sons organisés en pages. Importez vos fichiers audio et configurez vos pads. Volontairement simple (pas de DSP).",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
